#Copy this file to .env and fill in real values. Never commit .env.
# Expo automatically loads EXPO_PUBLIC_* vars at build time (SDK 49+) -
# no extra config needed. Restart `expo start` after changing this file.

# Your backend's base URL.
# Local dev (simulator/emulator on same machine): http://localhost:5000
# Physical device on your LAN: http://<your-computer-LAN-IP>:5000
# Production: your deployed backend URL (Render/AWS/etc.)
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# OpenWeatherMap API key (used by KrishiMitra weather widget)
# Get one at https://openweathermap.org/api
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# NewsAPI.org API key (used by KrishiMitra agri-news feed)
# Get one at https://newsapi.org
EXPO_PUBLIC_NEWSAPI_KEY=

# NOTE: EXPO_PUBLIC_* variables are bundled into the client JS and are
# visible to anyone who inspects the shipped app - this stops keys from
# living in git history and lets you swap them per environment, but it
# does NOT make them secret. For real key protection, proxy these calls
# through your backend instead of calling OpenWeatherMap/NewsAPI directly
# from the app.